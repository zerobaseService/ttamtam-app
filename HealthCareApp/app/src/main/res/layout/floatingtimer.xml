<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="72dp"
    android:elevation="8dp"
    android:background="@drawable/bg_white_round"
    android:paddingHorizontal="20dp">

    <TextView
        android:id="@+id/tv_bar_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="00:00:00"
        android:textColor="#1A202C"
        android:textSize="30sp"
        android:textStyle="bold"
        android:fontFamily="@font/pretendard"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/btn_bar_pause"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_marginStart="16dp"
        android:src="@drawable/pause"
        android:layout_marginEnd="16dp"
        app:layout_constraintBottom_toBottomOf="@id/tv_bar_time"
        app:layout_constraintEnd_toStartOf="@id/btn_bar_finish"
        app:layout_constraintTop_toTopOf="@id/tv_bar_time" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btn_bar_finish"
        android:layout_width="wrap_content"
        android:layout_height="38dp"
        android:paddingHorizontal="16dp"
        android:gravity="center"
        android:background="@drawable/bg_gray_round"
        android:text="운동 마치기"
        android:textColor="#4A5568"
        android:textSize="13sp"
        android:fontFamily="@font/pretendard"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>