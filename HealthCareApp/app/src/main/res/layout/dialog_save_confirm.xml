<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="339dp"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialog_round"
    android:orientation="vertical"
    android:paddingTop="24dp"
    android:paddingBottom="20dp">

    <!-- 텍스트 영역 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingStart="0dp"
        android:paddingEnd="0dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/pretendard"
            android:text="수정을 완료하시겠어요?"
            android:textColor="#000000"
            android:textSize="18sp"
            android:gravity="center"
            android:textStyle="normal" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="8dp">

            <TextView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:background="@drawable/bg_warning_circle"
                android:fontFamily="@font/pretendard"
                android:text="!"
                android:textColor="#8896A8"
                android:textSize="10sp"
                android:gravity="center"
                android:layout_marginEnd="6dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/pretendard"
                android:text="수정 완료 후에는 이전 기록은 사라져요"
                android:textColor="#8896A8"
                android:textSize="14sp" />
        </LinearLayout>

    </LinearLayout>

    <!-- 버튼 영역 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="24dp"
        android:paddingStart="18dp"
        android:paddingEnd="18dp">

        <FrameLayout
            android:id="@+id/btn_cancel"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:background="@drawable/bg_btn_cancel_soft">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:fontFamily="@font/pretendard"
                android:text="아니오"
                android:textColor="#2E3D4F"
                android:textSize="13sp" />
        </FrameLayout>

        <FrameLayout
            android:id="@+id/btn_confirm"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1"
            android:layout_marginStart="3dp"
            android:background="@drawable/bg_btn_confirm_blue">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:fontFamily="@font/pretendard"
                android:text="네"
                android:textColor="#FFFFFF"
                android:textSize="13sp" />
        </FrameLayout>

    </LinearLayout>

</LinearLayout>
