<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- [1] 상단 고정 영역: 상태바 및 타이틀 -->
    <ImageView
        android:id="@+id/statusbar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:adjustViewBounds="true"
        android:src="@drawable/status_bar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:ignore="MissingConstraints" />

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:fontFamily="@font/pretendard"
        android:text="컨디션 체크"
        android:textColor="#2D3A4B"
        android:textSize="15sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/statusbar" />

    <ImageView
        android:id="@+id/btn_close_condition"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginEnd="20dp"
        android:padding="2dp"
        android:src="@drawable/folder4_close"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/tv_title"
        app:layout_constraintBottom_toBottomOf="@id/tv_title" />

    <!-- [2] 스크롤 가능 영역 -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_title">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="30dp">

            <!-- 타이머 및 시간 영역 -->


            <!-- 상태 질문 영역 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="18dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp"
                android:text="상태 질문"
                android:textColor="#181818"
                android:textSize="18sp"
                android:fontFamily="@font/pretendard"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_status_questions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:overScrollMode="never"
                tools:listitem="@layout/item_condition_question_v2" />

            <!-- 통증 부위 선택 영역 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="18dp"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="12dp"
                android:text="통증 부위"
                android:textColor="#181818"
                android:textSize="18sp"
                android:fontFamily="@font/pretendard"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="18dp"
                android:background="@drawable/bg_tab_container"
                android:orientation="horizontal"
                android:padding="4dp">

                <LinearLayout
                    android:id="@+id/btn_front"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_tab_selected"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:id="@+id/tv_front_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="앞면"
                        android:textColor="#4A5768"
                        android:textSize="13sp"
                        android:fontFamily="@font/pretendard"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_front_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="2dp"
                        android:text="0"
                        android:textColor="#53A1FF"
                        android:textSize="13sp"
                        android:fontFamily="@font/pretendard"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btn_back"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:id="@+id/tv_back_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="뒷면"
                        android:textColor="#8896A8"
                        android:textSize="13sp"
                        android:fontFamily="@font/pretendard" />

                    <TextView
                        android:id="@+id/tv_back_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="2dp"
                        android:text="0"
                        android:textColor="#8896A8"
                        android:textSize="13sp"
                        android:fontFamily="@font/pretendard" />
                </LinearLayout>
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="18dp"
                android:layout_marginTop="8dp"
                app:cardBackgroundColor="@android:color/white"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeColor="#E1E7EE"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingTop="16dp"
                    android:paddingBottom="16dp">

                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:scrollbars="none"
                        android:layout_marginStart="18dp">

                        <com.google.android.material.chip.ChipGroup
                            android:id="@+id/chip_group_body"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:selectionRequired="true"
                            app:singleSelection="true">

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chip_head"
                                style="@style/Widget.MaterialComponents.Chip.Choice"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:checked="true"
                                android:text="머리/목"
                                android:textColor="@color/chip_text_selector"
                                app:chipBackgroundColor="@color/chip_selector" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chip_upper"
                                style="@style/Widget.MaterialComponents.Chip.Choice"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="상체"
                                android:textColor="@color/chip_text_selector"
                                app:chipBackgroundColor="@color/chip_selector" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chip_arm"
                                style="@style/Widget.MaterialComponents.Chip.Choice"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="팔/손"
                                android:textColor="@color/chip_text_selector"
                                app:chipBackgroundColor="@color/chip_selector" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chip_lower"
                                style="@style/Widget.MaterialComponents.Chip.Choice"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="하체"
                                android:textColor="@color/chip_text_selector"
                                app:chipBackgroundColor="@color/chip_selector" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chip_foot"
                                style="@style/Widget.MaterialComponents.Chip.Choice"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="발"
                                android:textColor="@color/chip_text_selector"
                                app:chipBackgroundColor="@color/chip_selector" />
                        </com.google.android.material.chip.ChipGroup>
                    </HorizontalScrollView>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_body_parts"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"
                        tools:listitem="@layout/item_body_part_selection" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 선택된 통증 태그 -->
            <TextView
                android:id="@+id/tv_pain_tag_placeholder"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="18dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_selected_tag"
                android:gravity="center_vertical"
                android:paddingHorizontal="12dp"
                android:paddingVertical="10dp"
                android:text="통증 부위를 선택해주세요"
                android:textColor="#8896A8"
                android:textSize="14sp"
                android:fontFamily="@font/pretendard" />

            <LinearLayout
                android:id="@+id/layout_selected_pain_tags"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="18dp"
                android:layout_marginTop="8dp"
                android:orientation="vertical"
                android:visibility="gone" />

            <!-- 메모 영역 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="12dp"
                android:text="메모/피드백"
                android:textColor="#2D3A4B"
                android:textSize="18sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_feedback_memo"
                android:layout_width="match_parent"
                android:layout_height="150dp"
                android:layout_marginHorizontal="24dp"
                android:background="@drawable/bg_memo_input"
                android:gravity="top"
                android:hint="운동을 하면서 생긴 특이사항이나 피드백을\n작성해 공유해보세요"
                android:inputType="textMultiLine"
                android:lineSpacingExtra="4dp"
                android:padding="16dp"
                android:textColor="#475569"
                android:textColorHint="#94A3B8"
                android:textSize="14sp" />

            <!-- 작성 완료 버튼 -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_finish_workout"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="32dp"
                android:background="@drawable/bg_finish_button"
                android:text="작성 완료"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />

            <View
                android:layout_width="match_parent"
                android:layout_height="100dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>