<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingVertical="10dp">

    <TextView
        android:id="@+id/tv_set_number"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/pretendard"
        android:text="1"
        android:textColor="#4A5768"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tv_label_set"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="4dp"
        android:fontFamily="@font/pretendard"
        android:text=" 세트"
        android:textColor="#B1B8C0"
        android:textSize="14sp"
        app:layout_constraintBottom_toBottomOf="@id/tv_set_number"
        app:layout_constraintStart_toEndOf="@id/tv_set_number"
        app:layout_constraintTop_toTopOf="@id/tv_set_number" />

    <EditText
        android:id="@+id/et_duration"
        android:layout_width="70dp"
        android:layout_height="45dp"
        android:layout_marginStart="20dp"
        android:background="@drawable/shape_gray_exedit"
        android:gravity="center"
        android:hint="0"
        android:inputType="number"
        android:fontFamily="@font/pretendard"
        android:textColor="#2D3A4B"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@id/tv_label_set"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tv_label_min"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="6dp"
        android:text=" 분"
        android:textColor="#B1B8C0"
        android:textSize="14sp"
        app:layout_constraintBottom_toBottomOf="@id/et_duration"
        app:layout_constraintStart_toEndOf="@id/et_duration"
        app:layout_constraintTop_toTopOf="@id/et_duration" />

</androidx.constraintlayout.widget.ConstraintLayout>
