<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardBackgroundColor="@android:color/white"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/tv_step_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1/5"
                android:textColor="#8896A8"
                android:textSize="14sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"/>
        </RelativeLayout>

        <TextView
            android:id="@+id/tv_question_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="운동 후 평소와 다른 관절/근육\n통증이 있었나요?"
            android:textColor="#181818"
            android:textSize="18sp"
            android:fontFamily="@font/pretendard"

             />

        <TextView
            android:id="@+id/tv_slider_guide"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="#F0F4F9"
            android:gravity="center"
            android:fontFamily="@font/pretendard"
            android:padding="14dp"
            android:text="4 - 가벼운 불편감이 있음"
            android:textColor="#808D9E"
            android:textSize="15sp"
            />

        <SeekBar
            android:id="@+id/slider"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:max="10"
            android:progress="1"
            android:progressDrawable="@drawable/custom_slider_trak"
            android:splitTrack="false"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:thumbOffset="0dp" />

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp">

            <TextView
                android:id="@+id/tv_min_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="통증 없음"
                android:textColor="#AAAAAA"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tv_max_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:text="매우 심함"
                android:textColor="#AAAAAA"
                android:textSize="13sp" />
        </RelativeLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>