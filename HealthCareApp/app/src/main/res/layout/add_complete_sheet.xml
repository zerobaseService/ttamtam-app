<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="339dp"
    android:layout_height="289dp"
    android:layout_gravity="center"
    android:background="@drawable/bottom_background1"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="공유폴더 추가"
        android:textStyle="bold"
        android:textColor="#2D3A4B"
        android:textSize="16sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:ignore="MissingConstraints">

    </TextView>

    <ImageView
        android:id="@+id/iv_complete_check"
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:layout_marginTop="50dp"
        android:src="@drawable/add_check"
        app:layout_constraintBottom_toTopOf="@+id/tv_complete_title"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
         />

    <TextView
        android:id="@+id/tv_complete_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="폴더 등록이 완료되었습니다"
        android:textColor="#2D3A4B"
        android:textSize="14sp"

        app:layout_constraintBottom_toTopOf="@+id/tv_complete_subtitle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/iv_complete_check" />

    <TextView
        android:id="@+id/tv_complete_subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"

        android:text="폴더 리스트에서 바로 확인하실 수 있습니다"
        android:textColor="#2D3A4B"
        android:textSize="14sp"
        app:layout_constraintBottom_toTopOf="@+id/tv_complete_title"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_complete_title" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btn_submit_add"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="32dp"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:background="@drawable/shape_dark"
        android:text="확인"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        tools:ignore="MissingConstraints" />

</androidx.constraintlayout.widget.ConstraintLayout>