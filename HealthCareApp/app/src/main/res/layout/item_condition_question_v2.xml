<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="18dp"
    android:layout_marginVertical="4dp"
    app:cardBackgroundColor="@android:color/white"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:strokeColor="#E1E7EE"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <TextView
            android:id="@+id/tv_step_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1/5"
            android:textColor="#8896A8"
            android:textSize="14sp"
            android:fontFamily="@font/pretendard" />

        <TextView
            android:id="@+id/tv_question_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="운동 후 평소와 다른 관절/근육\n통증이 있었나요?"
            android:textColor="#181818"
            android:textSize="15sp"
            android:fontFamily="@font/pretendard" />

        <TextView
            android:id="@+id/tv_slider_guide"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_guide_chip"
            android:gravity="center"
            android:fontFamily="@font/pretendard"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp"
            android:text="4 - 가벼운 불편감이 있음"
            android:textColor="#808D9E"
            android:textSize="13sp" />

        <com.example.healthcareapp.widget.DotSliderView
            android:id="@+id/slider"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp" />

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp">

            <TextView
                android:id="@+id/tv_min_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="통증 없음"
                android:textColor="#8896A8"
                android:textSize="13sp"
                android:fontFamily="@font/pretendard" />

            <TextView
                android:id="@+id/tv_max_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:text="매우 심함"
                android:textColor="#8896A8"
                android:textSize="13sp"
                android:fontFamily="@font/pretendard" />
        </RelativeLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
