{
  "info": {
    "name": "ttamtam - Healthcare API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "token1",
      "value": "",
      "type": "string"
    },
    {
      "key": "token2",
      "value": "",
      "type": "string"
    },
    {
      "key": "folderId",
      "value": "1",
      "type": "string"
    },
    {
      "key": "inviteToken",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "구글 로그인 - 트레이너 김민수",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var res = pm.response.json();",
                  "if (res.accessToken) {",
                  "    pm.collectionVariables.set('token1', res.accessToken);",
                  "    console.log('token1 저장 완료:', res.accessToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idToken\": \"fake-google-token-trainer\",\n  \"email\": \"trainer@ttamtam.com\",\n  \"nickname\": \"트레이너 김민수\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/google",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "google"]
            }
          }
        },
        {
          "name": "구글 로그인 - 회원 이지영",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var res = pm.response.json();",
                  "if (res.accessToken) {",
                  "    pm.collectionVariables.set('token2', res.accessToken);",
                  "    console.log('token2 저장 완료:', res.accessToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idToken\": \"fake-google-token-member\",\n  \"email\": \"member@ttamtam.com\",\n  \"nickname\": \"회원 이지영\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/google",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "google"]
            }
          }
        }
      ]
    },
    {
      "name": "Folder - 정상 흐름",
      "item": [
        {
          "name": "폴더 생성",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var res = pm.response.json();",
                  "if (res.folderId) {",
                  "    pm.collectionVariables.set('folderId', res.folderId);",
                  "    console.log('folderId 저장:', res.folderId);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token1}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"김민수의 운동 일지\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/folders",
              "host": ["{{baseUrl}}"],
              "path": ["api", "folders"]
            }
          }
        },
        {
          "name": "폴더 목록 조회",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token1}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/folders?size=20&sort=UPDATED_AT",
              "host": ["{{baseUrl}}"],
              "path": ["api", "folders"],
              "query": [
                { "key": "size", "value": "20" },
                { "key": "sort", "value": "UPDATED_AT" },
                { "key": "cursor", "value": "", "disabled": true },
                { "key": "shared", "value": "true", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "폴더 목록 조회 - 공유 폴더만 (shared=true)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token1}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/folders?shared=true",
              "host": ["{{baseUrl}}"],
              "path": ["api", "folders"],
              "query": [
                { "key": "shared", "value": "true" }
              ]
            }
          }
        },
        {
          "name": "폴더 목록 조회 - 개인 폴더만 (shared=false)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token1}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/folders?shared=false",
              "host": ["{{baseUrl}}"],
              "path": ["api", "folders"],
              "query": [
                { "key": "shared", "value": "false" }
              ]
            }
          }
        },
        {
          "name": "폴더 단일 조회",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token1}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/folders/{{folderId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "folders", "{{folderId}}"]
            }
          }
        },
        {
          "name": "폴더 이름 수정",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token1}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"수정된 폴더 이름\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/folders/{{folderId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "folders", "{{folderId}}"]
            }
          }
        },
        {
          "name": "초대 링크 생성",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var res = pm.response.json();",
                  "if (res.inviteLink) {",
                  "    var url = res.inviteLink;",
                  "    var token = url.split('token=')[1];",
                  "    pm.collectionVariables.set('inviteToken', token);",
                  "    console.log('inviteToken 저장:', token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token1}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/folders/{{folderId}}/invite-link",
              "host": ["{{baseUrl}}"],
              "path": ["api", "folders", "{{folderId}}", "invite-link"]
            }
          }
        },
        {
          "name": "초대 수락 (회원 이지영)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token2}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"folderId\": {{folderId}},\n  \"token\": \"{{inviteToken}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/folders/invite/accept",
              "host": ["{{baseUrl}}"],
              "path": ["api", "folders", "invite", "accept"]
            }
          }
        },
        {
          "name": "폴더 나가기 (회원 이지영)",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token2}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/folders/{{folderId}}/members/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "folders", "{{folderId}}", "members", "me"]
            }
          }
        },
        {
          "name": "폴더 나가기 (트레이너 - 마지막 멤버 → CLOSED)",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token1}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/folders/{{folderId}}/members/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "folders", "{{folderId}}", "members", "me"]
            }
          }
        }
      ]
    },
    {
      "name": "Folder - 에러 케이스",
      "item": [
        {
          "name": "[403] 인증 없이 호출",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/folders",
              "host": ["{{baseUrl}}"],
              "path": ["api", "folders"]
            }
          }
        },
        {
          "name": "[403] 권한 없는 폴더 접근",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token2}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/folders/{{folderId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "folders", "{{folderId}}"]
            }
          }
        },
        {
          "name": "[404] 존재하지 않는 폴더 조회",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token1}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/folders/99999",
              "host": ["{{baseUrl}}"],
              "path": ["api", "folders", "99999"]
            }
          }
        },
        {
          "name": "[400] 폴더명 19자 초과",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token1}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"가나다라마바사아자차카타파하가나다라마\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/folders",
              "host": ["{{baseUrl}}"],
              "path": ["api", "folders"]
            }
          }
        },
        {
          "name": "[400] 폴더명에 줄바꿈 포함",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token1}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"폴더이름\\n줄바꿈\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/folders",
              "host": ["{{baseUrl}}"],
              "path": ["api", "folders"]
            }
          }
        },
        {
          "name": "[409] 꽉 찬 폴더에 초대 링크 발급",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token1}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/folders/{{folderId}}/invite-link",
              "host": ["{{baseUrl}}"],
              "path": ["api", "folders", "{{folderId}}", "invite-link"]
            }
          }
        },
        {
          "name": "[400] 유효하지 않은 초대 토큰으로 수락",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token2}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"folderId\": {{folderId}},\n  \"token\": \"invalid-token-00000000\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/folders/invite/accept",
              "host": ["{{baseUrl}}"],
              "path": ["api", "folders", "invite", "accept"]
            }
          }
        },
        {
          "name": "[400] 이미 나간 멤버가 재시도",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token2}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/folders/{{folderId}}/members/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "folders", "{{folderId}}", "members", "me"]
            }
          }
        }
      ]
    }
  ]
}
